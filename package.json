{
  "name": "quality-gate",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic CI/CD quality gate for AI-assisted codebases. Ratchet-based regression detection with AI as advisory layer only.",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "quality:report": "node scripts/quality/quality-gate.js report",
    "quality:check": "node scripts/quality/quality-gate.js check",
    "quality:baseline": "node scripts/quality/quality-gate.js baseline",
    "quality:comment": "node scripts/quality/render-pr-comment.js",
    "quality:validate": "node scripts/quality/validate-config.js",
    "quality:explainer-context": "node scripts/quality/run-explainer-context.js",
    "quality:hybrid-report": "node scripts/quality/hybrid-report.js",
    "audit:report": "node scripts/quality/run-audit-report.js",
    "complexity:ci": "node scripts/quality/run-complexity-report.js",
    "test:quality": "node tests/run-node-tests.js tests/quality",
    "test:integration": "node tests/run-node-tests.js tests/integration",
    "test:coverage:ci": "c8 --all --include=scripts/quality/*.js --report-dir coverage --reporter=json-summary --reporter=text --check-coverage --lines 80 --statements 80 --functions 80 --branches 70 node tests/run-node-tests.js tests/quality tests/integration",
    "duplication:ci": "jscpd --config .jscpd.json --noTips scripts/quality tests",
    "lint": "eslint ."
  },
  "keywords": [
    "quality-gate",
    "ci-cd",
    "ratchet",
    "ai-review",
    "claude-code",
    "codex",
    "google-antigravity",
    "github-actions"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "c8": "10.1.3",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "jscpd": "4.1.1"
  }
}
